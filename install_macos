#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"

if [[ -n "${SUDO_USER:-}" ]]; then
  APP_USER="$SUDO_USER"
else
  APP_USER="$USER"
fi

resolve_home_dir() {
  local user="$1"
  local home=""

  if command -v dscl >/dev/null 2>&1; then
    home="$(dscl . -read "/Users/$user" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
  fi

  if [[ -z "$home" ]]; then
    home="$(eval echo "~$user")"
  fi

  if [[ -z "$home" || ! -d "$home" ]]; then
    return 1
  fi

  printf "%s" "$home"
}

APP_HOME="$(resolve_home_dir "$APP_USER" || true)"
if [[ -z "$APP_HOME" ]]; then
  echo "Could not determine home directory for user: $APP_USER"
  exit 1
fi

VENV_DIR="${VENV_DIR:-$APP_HOME/klippervault-venv}"
REQUIREMENTS_FILE="${REQUIREMENTS_FILE:-$APP_DIR/requirements.txt}"
CONFIG_DIR="$APP_HOME/Library/Application Support/KlipperVault"
DB_PATH="$APP_HOME/Library/Application Support/KlipperVault/klipper_macros.db"

need_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd"
    exit 1
  fi
}

as_user() {
  if [[ "$(id -un)" == "$APP_USER" ]]; then
    "$@"
  elif command -v sudo >/dev/null 2>&1; then
    sudo -u "$APP_USER" -- "$@"
  else
    echo "Cannot switch to user '$APP_USER' because sudo is not available."
    exit 1
  fi
}

echo "Installing KlipperVault (remote-only mode) on macOS"
echo "App dir: $APP_DIR"
echo "User: $APP_USER"
echo "Python: $PYTHON_BIN"
echo "Venv: $VENV_DIR"

after_install_cmd="$VENV_DIR/bin/python $APP_DIR/klipper_vault_gui.py"

need_cmd "$PYTHON_BIN"

if [[ ! -f "$REQUIREMENTS_FILE" ]]; then
  echo "Requirements file not found: $REQUIREMENTS_FILE"
  exit 1
fi

as_user mkdir -p "$CONFIG_DIR"
as_user mkdir -p "$(dirname "$DB_PATH")"

if [[ ! -d "$VENV_DIR" ]]; then
  echo "Creating virtual environment..."
  as_user "$PYTHON_BIN" -m venv "$VENV_DIR"
fi

echo "Installing Python dependencies..."
as_user "$VENV_DIR/bin/pip" install --upgrade pip
as_user "$VENV_DIR/bin/pip" install -r "$REQUIREMENTS_FILE"

echo "Settings are initialized automatically in the SQLite database on first start."

echo
echo "Install complete."
echo "Config dir: $CONFIG_DIR"
echo "Database: $DB_PATH"
echo "Start KlipperVault with: $after_install_cmd"
