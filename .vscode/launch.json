{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: NiceGUI App (configured port)",
      "type": "python",
      "request": "launch",
      "python": "/usr/bin/python3",
      "program": "${workspaceFolder}/klipper_vault.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "/home/shadowrom/.local/lib/python3.13/site-packages"
      }
    },
    {
      "name": "Python: Index Macros (CLI)",
      "type": "python",
      "request": "launch",
      "python": "/usr/bin/python3",
      "program": "${workspaceFolder}/src/klipper_macro_indexer.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "args": [
        "--config-dir",
        "${env:HOME}/printer_data/config",
        "--db-path",
        "${env:HOME}/printer_data/db/klipper_macros.db"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "/home/shadowrom/.local/lib/python3.13/site-packages"
      }
    },
    {
      "name": "Python: Index Macros (CLI, prune stale)",
      "type": "python",
      "request": "launch",
      "python": "/usr/bin/python3",
      "program": "${workspaceFolder}/src/klipper_macro_indexer.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "args": [
        "--config-dir",
        "${env:HOME}/printer_data/config",
        "--db-path",
        "${env:HOME}/printer_data/db/klipper_macros.db",
        "--prune"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": "/home/shadowrom/.local/lib/python3.13/site-packages"
      }
    }
  ]
}
